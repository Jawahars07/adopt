# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.
# Without a key, the app runs in offline DEMO mode (heuristic analysis), so it still works.

# Anthropic API key (pay-as-you-go). Enables live model analysis.
ANTHROPIC_API_KEY=

# Optional model override (default: claude-sonnet-4-6)
ADOPT_MODEL=claude-sonnet-4-6
