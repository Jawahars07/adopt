# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.
# Adopt is MODEL-AGNOSTIC. With nothing set, it runs the offline heuristic ($0, no deps).

# Which backend to use: demo | ollama | openai | anthropic
LLM_PROVIDER=demo

# ── For LLM_PROVIDER=ollama (free, local, private — runs on your machine) ──
#   1) install: https://ollama.com   2) `ollama pull llama3.2`   3) set the two lines below
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434

# ── For LLM_PROVIDER=openai (ANY OpenAI-compatible endpoint) ──
#   Works with Groq (free tier!), OpenRouter, LM Studio, vLLM, or OpenAI.
#   Example — Groq free tier:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_your_free_groq_key

# ── For LLM_PROVIDER=anthropic (Claude, optional — no SDK used) ──
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=sk-ant-...
